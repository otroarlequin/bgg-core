# Obtén tu token en https://boardgamegeek.com/applications (app no comercial)
BGG_TOKEN=your-bearer-token-here
BGG_USERNAME=your-bgg-username

# Opcional: ruta de la base de datos SQLite (default: ./data/bgg.db)
# BGG_DB_PATH=./data/bgg.db

# Opcional: directorio de salida para actividades generativas
# BGG_OUTPUT_DIR=./output

# Producción (Fly): contraseña compartida para Basic Auth (usuario puede ser cualquiera)
# APP_PASSWORD=elige-una-clave-fuerte

# Opcional: origen extra CORS si el front no se sirve desde la misma API
# CORS_ORIGIN=https://bgg-core.fly.dev
